# Copy this file to `.env.local` for local development or `.env` for committed
# baseline values. Only variables prefixed with REACT_APP_ are read by CRA.
#
# SECURITY NOTE: Every REACT_APP_* value is INLINED into the production bundle
# at build time and is visible to anyone who views your site. Do not put real
# secrets here. Treat these as configuration, not credentials.

# Password for /admin. Default is "admin" if unset. Change this before
# deploying — but also know that anyone with browser devtools can read it.
# For a real auth boundary you need a backend, which is out of scope.
REACT_APP_ADMIN_PASSWORD=admin

# Base URL for API calls (used by src/config/requests.js). Leave blank for
# same-origin requests, or set to something like https://api.example.com.
REACT_APP_API_HOST=

# Optional: the contact form's submit-target email. If set, overrides the
# address stored in site.json / admin panel. Leave blank to use site data.
REACT_APP_CONTACT_EMAIL=

# Optional: default URL for the "Download CV" button. Overrides site.cvUrl
# if set (useful for staging/production with different asset paths).
REACT_APP_CV_URL=
